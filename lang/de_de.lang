# Einstellungen-Seite
media_negotiator_config_title = Einstellungen
media_negotiator_config_force_imagick_label = Imagick erzwingen (auch wenn GD-Funktionen vorhanden sind)
media_negotiator_config_disable_avif_label = AVIF deaktivieren
media_negotiator_config_disable_avif_notice = Wenn der Server über keinen AVIF-Codec verfügt, kann die AVIF-Generierung hier deaktiviert werden.
